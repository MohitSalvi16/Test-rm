# ── LLM gateway (OpenAI-compatible /chat/completions) ──
# These map to the URLs/tokens from your audio/image/chat snippets.
LLM_BASE_URL=https://some-url
LLM_API_TOKEN=test-token
LLM_MODEL_CHAT=model-name
LLM_MODEL_AUDIO=model-name
LLM_MODEL_VISION=model-test
# Your snippets used verify=False. Keep false only for trusted internal gateways.
LLM_VERIFY_SSL=false
LLM_TIMEOUT=120

# ── pgvector (Postgres) ──
DATABASE_URL=postgresql+psycopg://rm:rm@localhost:5433/rmsolver

# ── Embeddings ──
# If sentence-transformers is installed this model is used; otherwise a
# deterministic hash embedder of the same dimension is used (offline-safe).
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIM=384
