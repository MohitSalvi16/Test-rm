# ── LLM gateway (OpenAI-compatible /chat/completions) ──
# REPLACE these placeholders with your real gateway URL + token to enable
# classification / audio-transcription / image-OCR.
LLM_BASE_URL=https://some-url
LLM_API_TOKEN=test-token
LLM_MODEL_CHAT=model-name
LLM_MODEL_AUDIO=model-name
LLM_MODEL_VISION=model-test
LLM_VERIFY_SSL=false
LLM_TIMEOUT=120

# ── pgvector (Postgres) ── currently running via docker compose on host :5433
DATABASE_URL=postgresql+psycopg://rm:rm@localhost:5433/rmsolver

# ── Embeddings ── falls back to hash embedder if sentence-transformers absent
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIM=384
